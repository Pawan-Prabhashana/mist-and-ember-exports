# -----------------------------------------------------
# 🌿 Ceylon Roots — Example Environment Configuration
# -----------------------------------------------------
# This file shows all environment variables used in the
# Next.js + TypeScript + CMS setup.
# Copy this file to `.env.local` and replace values with
# your actual credentials.
# -----------------------------------------------------

# -----------------------------------------------------
# ✅ NEXT.JS BASE CONFIGURATION
# -----------------------------------------------------

# Public site URL (used for canonical tags, OG, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://www.ceylonroots.com

# Environment mode: development | production
NODE_ENV=development

# Application name (used in metadata)
NEXT_PUBLIC_APP_NAME=Ceylon Roots

# Default language/locale
NEXT_PUBLIC_DEFAULT_LOCALE=en

# -----------------------------------------------------
# 🧠 CMS / CONTENT SOURCE (e.g., Sanity, Hygraph, Contentful)
# -----------------------------------------------------

# Example for Sanity:
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_TOKEN=your_sanity_api_token_here

# Example for Hygraph / GraphCMS (if used)
# NEXT_PUBLIC_HYGRAPH_URL=https://api-ap-southeast-1.hygraph.com/v2/your_project_id/master
# HYGRAPH_TOKEN=your_hygraph_token_here

# -----------------------------------------------------
# 📬 EMAIL / CONTACT FORM CONFIGURATION
# -----------------------------------------------------

# EmailJS / Resend / SendGrid / SMTP (choose one)
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key_here

# Receiver email for contact form submissions
CONTACT_FORM_RECEIVER=hello@ceylonroots.com

# Optional SMTP configuration (if using nodemailer)
# SMTP_HOST=smtp.mailserver.com
# SMTP_PORT=465
# SMTP_USER=your_email@domain.com
# SMTP_PASS=your_password_here

# -----------------------------------------------------
# 🌐 SEO & ANALYTICS
# -----------------------------------------------------

# Google Analytics / GA4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Plausible Analytics (alternative to GA)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=ceylonroots.com

# Open Graph default image path (used in og-generator script)
NEXT_PUBLIC_OG_DEFAULT=/images/og-default.jpg

# -----------------------------------------------------
# ☁️ THIRD-PARTY SERVICES / INTEGRATIONS
# -----------------------------------------------------

# Cloudinary (for image optimization and storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Map provider key (if using embedded maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# ReCAPTCHA for contact form (if used)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# -----------------------------------------------------
# 🧩 INTERNAL / CUSTOM CONFIG
# -----------------------------------------------------

# Build-time cache key or secret (used for image optimizer, OG generator, etc.)
BUILD_SECRET_KEY=dev_build_secret_key_here

# Path for generated Open Graph images
OG_IMAGE_OUTPUT_PATH=public/og/

# Optional: Enable debug logs (true/false)
DEBUG_LOGS=false

# -----------------------------------------------------
# 🪄 MISC
# -----------------------------------------------------

# API route example (if you connect to external backends)
NEXT_PUBLIC_API_BASE_URL=https://api.ceylonroots.com

# Public contact info (for Footer / About sections)
NEXT_PUBLIC_CONTACT_PHONE=+94 77 123 4567
NEXT_PUBLIC_CONTACT_EMAIL=info@ceylonroots.com
NEXT_PUBLIC_CONTACT_ADDRESS=Colombo, Sri Lanka
