{
  // -----------------------------------------------------
  // 🌿 Ceylon Roots — Prettier Configuration
  // -----------------------------------------------------
  // Ensures consistent code formatting for the entire project.
  // Works seamlessly with TypeScript, React, and TailwindCSS.
  // -----------------------------------------------------

  "semi": true,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "quoteProps": "consistent",
  "htmlWhitespaceSensitivity": "css",
  "embeddedLanguageFormatting": "auto",
  "proseWrap": "preserve",

  // -----------------------------------------------------
  // 🧠 Plugins
  // -----------------------------------------------------
  "plugins": [
    "prettier-plugin-tailwindcss"
  ],

  // -----------------------------------------------------
  // 🎨 Overrides per file type
  // -----------------------------------------------------
  "overrides": [
    {
      "files": ["*.json", "*.yml", "*.yaml"],
      "options": {
        "printWidth": 80
      }
    },
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "proseWrap": "always",
        "printWidth": 80
      }
    },
    {
      "files": ["*.tsx", "*.jsx"],
      "options": {
        "jsxBracketSameLine": false
      }
    }
  ]
}
